# ============================================================
# .env.example — copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── Google Drive API key (optional) ─────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Drive API first.
# Folders must be shared as "Anyone with the link can view".
# Leave blank to disable Drive sync.
GOOGLE_API_KEY=AIza...your-api-key...
